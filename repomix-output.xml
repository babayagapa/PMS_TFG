<file path="pms-backend/app/Models/Reserva.php">
<?php

namespace App\Models;

use MongoDB\Laravel\Eloquent\Model;
use Carbon\Carbon;

class Reserva extends Model
{
    protected $connection = 'mongodb';
    protected $collection = 'reservas';

    protected $fillable = [
        'id_cliente',
        'id_habitacion',
        'nombre_huesped',
        'email_huesped',
        'telefono_huesped',
        'fecha_entrada',
        'fecha_salida',
        'num_huespedes',
        'precio_total',
        'estado',
        'notas',
    ];

    protected $casts = [
        'precio_total'  => 'float',
        'num_huespedes' => 'integer',
    ];

    public static function calcularPrecio(float $precioNoche, string $entrada, string $salida): float
    {
        $noches = Carbon::parse($entrada)->diffInDays(Carbon::parse($salida));
        if ($noches <= 0) return 0.0;
        return round($precioNoche * $noches * 1.10, 2);
    }

    public function habitacion()
    {
        return $this->belongsTo(Habitacion::class, 'id_habitacion');
    }

    public function cliente()
    {
        return $this->belongsTo(User::class, 'id_cliente');
    }
}
