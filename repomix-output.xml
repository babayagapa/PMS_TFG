version: '3.8'

services:

  mongo:
    image: mongo:6
    container_name: pms_mongo
    restart: unless-stopped
    environment:
      MONGO_INITDB_ROOT_USERNAME: admin
      MONGO_INITDB_ROOT_PASSWORD: secret
      MONGO_INITDB_DATABASE: pms_db
    ports:
      - "27017:27017"
    volumes:
      - mongo_data:/data/db
    networks:
      - pms_net

  mongo-express:
    image: mongo-express
    container_name: pms_mongo_ui
    restart: unless-stopped
    depends_on:
      - mongo
    environment:
      ME_CONFIG_MONGODB_ADMINUSERNAME: admin
      ME_CONFIG_MONGODB_ADMINPASSWORD: secret
      ME_CONFIG_MONGODB_URL: mongodb://admin:secret@mongo:27017/
      ME_CONFIG_BASICAUTH: "false"
    ports:
      - "8081:8081"
    networks:
      - pms_net

  backend:
    build:
      context: ./pms-backend
      dockerfile: Dockerfile
    container_name: pms_backend
    restart: unless-stopped
    depends_on:
      - mongo
    ports:
      - "8000:8000"
    volumes:
      - ./pms-backend:/var/www/html
    environment:
      APP_NAME: PMS_TFG
