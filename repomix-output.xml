<file path="pms-frontend/src/index.css">
@tailwind base;
@tailwind components;
@tailwind utilities;

/* FUENTE Y FONDO GLOBAL */
body {
  margin: 0;
  font-family: 'Inter', sans-serif;
  background: linear-gradient(135deg, #E8F5E9 0%, #ffffff 100%);
  color: #2C3E50;
  min-height: 100vh;
}

/* WRAPPER DE PAGINA */
.page {
  min-height: 100vh;
  padding: 40px;
  box-sizing: border-box;
}

/* GLASSMORPHISM */
.glass {
  background: rgba(255, 255, 255, 0.4);
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
  border: 1px solid rgba(255, 255, 255, 0.6);
  border-radius: 16px;
  box-shadow: 0 8px 32px rgba(0, 0, 0, 0.05);
}

/* BOTON PRINCIPAL */
.btn-primary {
  background-color: #2ECC71;
  color: white;
  border: none;
  padding: 16px 32px;
  border-radius: 12px;
  font-size: 16px;
  font-weight: 700;
  cursor: pointer;
  font-family: 'Inter', sans-serif;
  transition: background 0.3s, transform 0.1s;
  display: inline-block;
  text-decoration: none;
}

.btn-primary:hover {
  background-color: #27AE60;
}

.btn-primary:active {
  transform: scale(0.98);
}

.btn-primary:disabled {
  opacity: 0.5;
  cursor: not-allowed;
}

/* BOTON SECUNDARIO */
.btn-secondary {
  background-color: transparent;
  color: #2ECC71;
  border: 2px solid #2ECC71;
  padding: 14px 32px;
  border-radius: 12px;
  font-size: 16px;
  font-weight: 700;
  cursor: pointer;
  font-family: 'Inter', sans-serif;
  transition: all 0.3s;
  text-decoration: none;
  display: inline-block;
}

.btn-secondary:hover {
  background-color: #2ECC71;
  color: white;
}

/* INPUTS Y SELECTS */
.input-field {
  padding: 14px;
  border: 1px solid rgba(44, 62, 80, 0.1);
  border-radius: 12px;
  background: rgba(255, 255, 255, 0.6);
  font-family: 'Inter', sans-serif;
  font-size: 15px;
  color: #2C3E50;
  outline: none;
  transition: background 0.3s, border-color 0.3s;
  width: 100%;
  box-sizing: border-box;
}

.input-field:focus {
  background: rgba(255, 255, 255, 0.9);
  border-color: #2ECC71;
}

/* LABEL DE FORMULARIO */
.input-label {
  font-size: 14px;
  font-weight: 600;
  color: #2C3E50;
  margin-bottom: 8px;
  display: block;
}

/* GRUPO DE INPUT */
.input-group {
  display: flex;
  flex-direction: column;
  flex: 1;
}

/* SPINNER */
.spinner {
  width: 32px;
  height: 32px;
  border: 4px solid rgba(46, 204, 113, 0.3);
  border-top-color: #2ECC71;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
  margin: 0 auto;
}

@keyframes spin {
