                <th style={{ padding: '10px 0', textAlign: 'right', fontWeight: 600, color: '#2C3E50', opacity: 0.7 }}>Precio unit.</th>
                <th style={{ padding: '10px 0', textAlign: 'right', fontWeight: 600, color: '#2C3E50', opacity: 0.7 }}>Subtotal</th>
